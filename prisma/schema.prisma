generator client {
  provider   = "prisma-client-js"
  // Binary engine avoids query_engine-windows.dll.node rename EPERM on locked DLL (common with AV / editors).
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  CUSTOMER
  KITCHEN
  DRIVER
  ADMIN
}

enum OrderStatus {
  PENDING_PAYMENT
  RECEIVED
  PREPARING
  READY
  PICKED_UP
  DELIVERED
  CANCELED
}

model User {
  id           String             @id @default(cuid())
  authUserId   String?            @unique
  email        String             @unique
  password     String
  role         Role
  name         String
  isActive     Boolean            @default(true)
  deletedAt    DateTime?
  orders       Order[]            @relation("CustomerOrders")
  actedEvents  OrderStatusEvent[]
  deliveries   DeliveryAssignment[]

  @@index([isActive, email])
}

model MenuCategory {
  id        String     @id @default(cuid())
  slug      String     @unique
  name      String
  sortOrder Int        @default(0)
  itemLinks MenuItemCategory[]
}

model MenuItem {
  id          String             @id @default(cuid())
  name        String
  description String      @default("")
  priceCents  Int
  imageUrl    String?
  isAvailable Boolean     @default(true)
  orderItems  OrderItem[]
  categoryLinks MenuItemCategory[]

  @@index([isAvailable, name])
}

model MenuItemCategory {
  menuItemId   String
  categoryId   String
  menuItem     MenuItem     @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  category     MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([menuItemId, categoryId])
  @@index([categoryId, menuItemId])
  @@index([menuItemId])
}

model Order {
  id          String             @id @default(cuid())
  customerId  String
  customer    User               @relation("CustomerOrders", fields: [customerId], references: [id])
  status      OrderStatus        @default(PENDING_PAYMENT)
  totalCents  Int
  createdAt   DateTime           @default(now())
  paidAt      DateTime?
  items       OrderItem[]
  events      OrderStatusEvent[]
  assignment  DeliveryAssignment?

  @@index([status, createdAt])
  @@index([customerId, createdAt])
}

model OrderItem {
  id                String   @id @default(cuid())
  orderId           String
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId        String
  menuItem          MenuItem @relation(fields: [menuItemId], references: [id])
  quantity          Int
  priceCentsAtOrder Int

  @@index([orderId])
  @@index([menuItemId])
}

model OrderStatusEvent {
  id          String       @id @default(cuid())
  orderId     String
  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus  OrderStatus?
  toStatus    OrderStatus
  actorUserId String?
  actor       User?        @relation(fields: [actorUserId], references: [id])
  at          DateTime     @default(now())

  @@index([orderId])
  @@index([at])
}

model DeliveryAssignment {
  id          String    @id @default(cuid())
  orderId     String    @unique
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driverId    String
  driver      User      @relation(fields: [driverId], references: [id])
  claimedAt   DateTime  @default(now())
  deliveredAt DateTime?

  @@index([driverId])
}
