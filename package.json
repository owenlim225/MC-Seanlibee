{
  "name": "mc-seanlibee",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild"
    ]
  },
  "scripts": {
    "postinstall": "node scripts/prisma-generate-retry.mjs",
    "dev": "next dev",
    "build": "prisma migrate deploy && node scripts/prisma-generate-retry.mjs && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "node scripts/prisma-generate-retry.mjs",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push --skip-generate",
    "db:seed": "prisma db seed",
    "db:backfill:auth-user-id": "tsx prisma/scripts/backfill-auth-user-id.ts",
    "db:studio": "prisma studio",
    "db:cleanup:broken-images": "tsx prisma/scripts/cleanup-broken-seeded-menu-images.ts",
    "db:verify:broken-images": "tsx prisma/scripts/verify-broken-image-cleanup.ts",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.3",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^16.4.7",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "6.19.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
