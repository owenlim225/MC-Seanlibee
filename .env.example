# Supabase API (required for Realtime and Storage mocks; use placeholder values locally)
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlvdXItcHJvamVjdC1pZCIsInJvbGUiOiJhbm9uIn0.placeholder

# PostgreSQL (Prisma) — Required
# Use pooled connection for DATABASE_URL (serverless runtime).
# Use direct connection for DIRECT_URL (migrations and introspection).
DATABASE_URL=postgresql://user:password@localhost:5432/mc_seanlibee?pgbouncer=true
DIRECT_URL=postgresql://user:password@localhost:5432/mc_seanlibee

# Session & Auth — Required
# Generate a random 64-char hex string: `openssl rand -hex 32`
SESSION_SECRET=your-64-character-hex-string-here-replace-with-random-value

# Optional: Seed data password (default: Demo123!)
# Used when running `pnpm db:seed` to create demo users
SEED_AUTH_PASSWORD=Demo123!

# Optional: E2E test password (default: hardcoded test value)
# Used by Playwright tests to create test accounts
E2E_AUTH_PASSWORD=Demo123!

# Optional: Supabase (mocked for MVP, enable later)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
