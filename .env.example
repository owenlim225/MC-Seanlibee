# PostgreSQL — copy to `.env` (see README deploy notes).
# Supabase: use pooled connection for DATABASE_URL and direct for migrations.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# Required for signed session cookies (use a long random value in production).
SESSION_SECRET="replace-with-long-random-string"

# Optional demo email/password login (`lib/auth/mock.ts`). Keep disabled on public prod unless intentional.
# DEMO_AUTH_ENABLED=true
# DEMO_AUTH_PASSWORD="choose-a-strong-demo-password"
