# SQLite dev DB (path relative to prisma/schema.prisma directory)
DATABASE_URL="file:./dev.db"

# Mock session signing (use a long random string in real deployments)
SESSION_SECRET="change-me-in-development-min-32-chars"

# --- Production (Vercel + Supabase Postgres) ---
# When deploying, switch prisma/schema.prisma `provider` from "sqlite" to "postgresql"
# and supply BOTH URLs below. Runtime queries use the pooled URL; migrations need direct.
#
# DATABASE_URL="postgres://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL="postgres://USER:PASSWORD@HOST:5432/postgres"

# --- Demo auth (env-gated email/password sign-in) ---
# Enable in production only behind a flag; password is constant-time compared.
# DEMO_AUTH_ENABLED="true"
# DEMO_AUTH_PASSWORD="set-a-long-random-string"
